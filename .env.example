# Host wallet address — only this wallet can create quiz rooms.
# Must be exposed to the client (NEXT_PUBLIC_*) so the landing page can
# conditionally show the "I'm Hosting" button. Enforced server-side too.
NEXT_PUBLIC_HOST_ADDRESS=0xYourHostAddressHere

# Optional: override the SQLite DB path. Defaults to ./quiz.db locally
# and /tmp/quiz.db on Vercel.
# QUIZ_DB_PATH=/tmp/quiz.db
