# ---------------------------------------------------------------------------
# Monorepo: three apps share this .env via symlinks
#   apps/api/.env   → ../../.env
#   apps/quiz/.env  → ../../.env
#   apps/admin/.env → ../../.env
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Shared (api + admin)
# ---------------------------------------------------------------------------

# Postgres — local dev points at the dockerized postgres from docker-compose.yml.
# Prod: set to the Neon pooled connection string.
DATABASE_URL=postgresql://miniquiz:miniquiz@localhost:5432/miniquiz?schema=public

# Shared JWT secret: admin app signs (NextAuth + backend-token), api verifies.
# Must match in both envs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-long-random-string

# ---------------------------------------------------------------------------
# apps/quiz (Next.js — MiniPay player app, port 3000)
# ---------------------------------------------------------------------------

# Backend base URL (exposed to the browser).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# apps/admin (Next.js — desktop CMS, port 3001)
# ---------------------------------------------------------------------------

# NextAuth base URL — must match the admin app's public URL.
NEXTAUTH_URL=http://localhost:3001

# Where the admin live-projector view should generate QR play URLs.
# This points at the QUIZ app's public origin.
NEXT_PUBLIC_QUIZ_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# apps/api (Fastify on VPS, port 4000)
# ---------------------------------------------------------------------------

PORT=4000

# Initial admin (only used by apps/api/src/seed-admin.ts on first boot).
# Idempotent — once an admin with this email exists in the AdminCredential
# table, the seed script no-ops. Remove these vars after the first bootstrap
# to make brute-force harder if the env ever leaks.
INITIAL_ADMIN_EMAIL=you@example.com
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password

# Treasury wallet that funds all prize payouts. Keep on the VPS only.
# 0x-prefixed 64-char hex string.
TREASURY_PRIVATE_KEY=

# Celo RPC endpoint.
CELO_RPC_URL=https://forno.celo.org

# CORS: comma-separated list of allowed origins. Both quiz + admin must be listed.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
