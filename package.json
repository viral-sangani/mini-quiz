{
  "name": "mini-quiz-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @mini-quiz/api dev",
    "dev:quiz": "pnpm --filter @mini-quiz/quiz dev",
    "dev:admin": "pnpm --filter @mini-quiz/admin dev",
    "dev:ngrok": "bash scripts/dev-ngrok.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "start": "turbo run start",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "pnpm --filter @mini-quiz/api prisma migrate dev",
    "db:generate": "pnpm --filter @mini-quiz/api prisma generate",
    "db:studio": "pnpm --filter @mini-quiz/api prisma studio",
    "db:seed": "pnpm --filter @mini-quiz/api seed",
    "loadtest:phase0": "node scripts/loadtest-phase0.mjs",
    "loadtest:phase2": "node scripts/loadtest-phase2.mjs"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
