// Mini Quiz — Prisma schema
// Run migrations with:  pnpm --filter @mini-quiz/api prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum QuizStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
  ARCHIVED
}

enum PayoutStatus {
  PENDING
  APPROVED
  BROADCAST
  CONFIRMED
  FAILED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// LIVE  — original scheduled multiplayer prize quizzes (the only kind that
//         existed before). Drives the live SSE broadcast + auto-payouts.
// DAILY — async 24h window; one play per user per UTC day. Aggregated into
//         a daily-only leaderboard; never mutates User.totalXp.
enum QuizKind {
  LIVE
  DAILY
}

// Token paid out as prize. CELO is the chain's native asset; USDC and USDT
// are ERC-20 stablecoins on Celo mainnet. The chain client picks the right
// transfer path (sendTransaction value vs. ERC-20 transfer) by symbol.
enum PayoutToken {
  CELO
  USDC
  USDT
}

// Unified User: admins authenticate via email+Google (NextAuth); players via
// their MiniPay wallet. walletAddress is lowercase. Either email or
// walletAddress (or both) can be null depending on the account type.
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  walletAddress String?   @unique
  displayName   String?
  // Player-only profile fields. username is unique + lowercase + [a-z0-9_]{3,20};
  // avatarEmoji is one of a curated set; avatarColor is one of the design tokens.
  username      String?   @unique
  avatarEmoji   String?
  avatarColor   String?
  // Lifetime XP — sum of all `Answer.points` earned. Used for level calc + the
  // "gems" stat on home/profile. Updated transactionally with each answer.
  totalXp       Int       @default(0)
  role          Role      @default(USER)
  // Moderation. Set by an admin via /admin/users/:id/flag. flaggedBy is the
  // admin who acted; flagReason is free-text. Cleared by /unflag.
  flagged       Boolean   @default(false)
  flagReason    String?
  flaggedAt     DateTime?
  flaggedById   String?
  // Soft delete. Set by admin via DELETE /admin/users/:id. Reads filter
  // `deletedAt: null` so the user disappears from /players, leaderboards,
  // room lists, and public profile lookups. Foreign keys (Answer, Payout,
  // RoomPlayer) survive — restore is a single SQL UPDATE.
  deletedAt     DateTime?
  // Daily-quiz streak fields. currentStreak counts consecutive UTC days a
  // daily play was finished; resets to 1 on a skipped day. Updated atomically
  // in daily.service.finishDailyPlay.
  currentStreak     Int       @default(0)
  longestStreak     Int       @default(0)
  lastDailyPlayedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  createdQuizzes Quiz[]       @relation("QuizCreator")
  practiceQuizzes PracticeQuiz[] @relation("PracticeQuizCreator")
  practicePlays   PracticePlay[]
  roomPlayers    RoomPlayer[]
  answers        Answer[]
  payouts        Payout[]
  approvedPayouts Payout[]    @relation("PayoutApprover")
  badges          UserBadge[]
  flaggedBy      User?     @relation("UserFlaggedBy", fields: [flaggedById], references: [id])
  flaggedUsers   User[]    @relation("UserFlaggedBy")
  // Admins authenticate via email + bcrypt-hashed password. Players have
  // adminCredential = null. Created by POST /admin/auth/admins (or seed).
  adminCredential AdminCredential?

  @@index([role])
  @@index([username])
  @@index([flagged])
}

// Admin password storage. 1:1 with User (PK is User.id). Created via the
// admin-auth API or the seed script; deleted when an admin is revoked.
// Kept separate from User so player rows stay clean and so password material
// can be dropped wholesale without touching User.
model AdminCredential {
  userId            String    @id
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash      String
  passwordUpdatedAt DateTime  @default(now())
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
}

// One row per (userId, badgeId). Awarded by badge.service.ts; idempotent via
// unique constraint. badgeId is a string from the BADGE_CATALOG in
// packages/shared/src/badges.ts (no enum so the catalog can grow without migrations).
model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

// NextAuth v5 Prisma adapter models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Quiz {
  id             String     @id @default(cuid())
  code           String     @unique
  title          String
  description    String?
  status         QuizStatus @default(DRAFT)
  scheduledStart DateTime?
  startedAt      DateTime?
  endedAt        DateTime?
  questionTimeMs Int
  prizeAmounts   String[]
  // Visual hints surfaced on player home cards + admin list. Stored as design
  // tokens (primary | berry | sky | accent | ink), mapped to CSS vars on render.
  difficulty     Difficulty @default(MEDIUM)
  coverColor     String     @default("primary")
  // LIVE = original prize quizzes; DAILY = async daily quiz. Discriminator
  // so the rest of the data model (Question/Answer/RoomPlayer) can be reused
  // unchanged. Public endpoints filter to LIVE; daily endpoints filter to DAILY.
  kind           QuizKind   @default(LIVE)
  // Set only for kind=DAILY. The UTC date the daily quiz is active. Combined
  // with kind into a unique key so at most one DAILY exists per UTC date.
  dailyDate      DateTime?  @db.Date
  // Which token is disbursed when this quiz auto-pays its winners. Default
  // USDT preserves pre-multi-token behavior on existing rows.
  payoutToken    PayoutToken @default(USDT)
  archivedAt     DateTime?
  createdById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  createdBy User         @relation("QuizCreator", fields: [createdById], references: [id])
  questions Question[]
  players   RoomPlayer[]
  payouts   Payout[]
  dailySnapshot DailyLeaderboardSnapshot?

  @@unique([kind, dailyDate], name: "uniq_daily_per_date")
  @@index([status, scheduledStart])
  @@index([archivedAt])
}

model Question {
  id              String   @id @default(cuid())
  quizId          String
  position        Int
  prompt          String
  choices         Json
  correctChoiceId String

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@unique([quizId, position])
}

model RoomPlayer {
  id       String   @id @default(cuid())
  quizId   String
  userId   String
  joinedAt DateTime @default(now())
  // Daily-quiz only: when the player first fetched a question. Submission
  // window closes at dailyStartedAt + 200_000ms (10 questions x 20s each).
  // NULL for live (kind=LIVE) rooms.
  dailyStartedAt     DateTime?
  // Daily-quiz only: per-play question order, Fisher-Yates shuffled at start.
  // Stored so a refresh re-renders the same order. NULL/[] for live rooms.
  dailyQuestionOrder String[]

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])
  answers Answer[]

  @@unique([quizId, userId])
  @@index([quizId])
}

model Answer {
  id           String   @id @default(cuid())
  roomPlayerId String
  questionId   String
  userId       String
  choiceId     String
  submittedAt  DateTime @default(now())
  timeTakenMs  Int
  isCorrect    Boolean
  points       Int

  roomPlayer RoomPlayer @relation(fields: [roomPlayerId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([roomPlayerId, questionId])
  @@index([questionId])
}

model Payout {
  id            String       @id @default(cuid())
  quizId        String
  userId        String
  rank          Int
  amount        String
  tokenAddress  String
  status        PayoutStatus @default(PENDING)
  approvedById  String?
  txHash        String?
  confirmedAt   DateTime?
  failureReason String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  quiz       Quiz  @relation(fields: [quizId], references: [id])
  user       User  @relation(fields: [userId], references: [id])
  approvedBy User? @relation("PayoutApprover", fields: [approvedById], references: [id])

  @@unique([quizId, rank])
  @@index([status])
}

// Practice mode — solo learning, no XP, no leaderboard. Each practice quiz
// has a mutable pool of questions; a play samples 10 random ones. Operators
// refresh pools every few days (with AI assistance). Per-quiz head count
// (`PracticePlay.userId` distinct count) is the only metric the admin
// console shows.
model PracticeQuiz {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  iconName    String   @default("book")
  coverColor  String   @default("primary")
  published   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User               @relation("PracticeQuizCreator", fields: [createdById], references: [id])
  questions PracticeQuestion[]
  plays     PracticePlay[]

  @@index([published])
}

model PracticeQuestion {
  id              String   @id @default(cuid())
  quizId          String
  prompt          String
  // Same shape as Question.choices: [{id, label}, ...]. JSON to keep it
  // schema-flexible.
  choices         Json
  correctChoiceId String
  // Why-correct copy shown after each answer. Optional so questions can be
  // authored without explanations if desired.
  explanation     String?
  createdAt       DateTime @default(now())

  quiz PracticeQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

// One row per (user, quiz, session). Used for head count + practice badge
// thresholds. Not used for any leaderboard. Keeps the played question IDs
// so the player can be shown which set of questions they got.
model PracticePlay {
  id           String    @id @default(cuid())
  quizId       String
  userId       String
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  questionIds  String[]
  scoreCorrect Int       @default(0)
  scoreTotal   Int       @default(0)

  quiz PracticeQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@index([quizId, userId])
  @@index([userId])
}

// Frozen daily leaderboard. Written by the scheduler's daily-housekeeping
// branch when a DAILY quiz transitions LIVE -> ENDED. Frozen rather than
// joined so retroactive user edits (rename, soft-delete) don't rewrite
// history. winnerUserId is denormalized for the "Daily wins" profile stat.
model DailyLeaderboardSnapshot {
  id           String   @id @default(cuid())
  date         DateTime @db.Date @unique
  quizId       String   @unique
  rows         Json
  winnerUserId String?
  createdAt    DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id])

  @@index([winnerUserId])
}
